# Artizan Moris — frontend environment template.
# Copy to .env.local for local dev, and set these in your host (Vercel /
# Cloudflare Pages) for production builds. Only NEXT_PUBLIC_* values ship to
# the browser — they are public by design. Never put service-role or other
# secrets here; those live inside Supabase Edge Functions.

# Supabase (public project URL + publishable/anon key)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Canonical site URL (used for metadata + sitemap)
NEXT_PUBLIC_SITE_URL=https://artizanmoris.octolabs.app

# Optional — Google AdSense. Leave unset to render no ads.
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_SEARCH_SLOT=xxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_REQUEST_SLOT=xxxxxxxxxx
# NEXT_PUBLIC_ADSENSE_ARTISAN_SLOT=xxxxxxxxxx
